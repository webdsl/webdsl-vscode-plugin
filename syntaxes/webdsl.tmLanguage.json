{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "WebDSL",
	"patterns": [
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [{
				"name": "keyword.control.webdsl",
				"match": "\\b(if|else|while|for|in|return|application|page|(email |ajax )?template|function|section|entity|extend|search|var|imports|access control rules|rule|module|from|as|where|limit|(left |right )?join|and|or|group by|order by|asc|desc|action|submit|principal is|with credentials)\\b"
			}]
		},
		"strings": {
			"name": "string.quoted.double.webdsl",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.webdsl",
					"match": "\\\\."
				}
			]
		}
	},
	"scopeName": "source.webdsl"
}