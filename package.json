{
  "name": "webdslvscodeplugin",
  "displayName": "WebDSL VSCode Plugin",
  "description": "WebDSL support in VS Code.",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/webdsl/webdsl-vscode-plugin"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "activationEvents": [
		"onLanguage:webdsl"
	],
  "main": "./out/extension.js",
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "webdsl",
        "aliases": [
          "WebDSL",
          "webdsl"
        ],
        "extensions": [
          ".app"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "webdsl",
        "scopeName": "source.webdsl",
        "path": "./syntaxes/webdsl.tmLanguage.json"
      }
    ],
    "semanticTokenTypes": [
      {"id": "keyword", "description": "keyword"},
      {"id": "operator", "description": "operator"}
    ],
    "semanticTokenModifiers": []
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "glob": "^11.0.0",
    "typescript": "^5.9.3",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.48.1",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
